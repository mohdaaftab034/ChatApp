NODE_ENV=development
PORT=4000
API_PREFIX=/api

# Primary frontend origin (required)
CLIENT_URL=http://localhost:5173

# Optional comma-separated list of extra allowed frontend origins
# Example: CLIENT_URLS=https://chatapp-web.onrender.com,https://staging-chatapp-web.onrender.com
CLIENT_URLS=

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Optional. If omitted, app runs without Redis-backed token persistence.
REDIS_URL=

# SMTP settings
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM=no-reply@example.com

# Optional legacy aliases used by env merging logic
NODEMAILER_EMAIL=
NODEMAILER_PASS=
NODEMAILER_HOST=
NODEMAILER_PORT=
NODEMAILER_FROM=

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret